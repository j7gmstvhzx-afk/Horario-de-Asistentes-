# PostgreSQL connection string (from Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# JWT secret for session cookies (generate with: openssl rand -base64 48)
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Token to protect the one-time /api/setup endpoint used to create the
# first admin user right after deploying. Generate with: openssl rand -hex 32
SETUP_TOKEN="replace-with-a-random-string"

# Token for the monthly PTO accrual cron. Generate with: openssl rand -hex 32
CRON_SECRET="replace-with-a-random-string"

# App config (informational)
NEXT_PUBLIC_APP_NAME="Horario de Asistentes"
NEXT_PUBLIC_CASINO_NAME="Casino Atlántico Manatí"
NEXT_PUBLIC_TIMEZONE="America/Puerto_Rico"

# Optional — only used by the local seed script (npm run db:seed).
# Ignored in production; use /api/setup for the production admin instead.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Administrador"
