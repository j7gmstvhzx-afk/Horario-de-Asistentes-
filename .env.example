# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/horario_asistentes?schema=public"

# JWT secret for session cookies (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# App config
NEXT_PUBLIC_APP_NAME="Horario de Asistentes"
NEXT_PUBLIC_CASINO_NAME="Casino Atlántico Manatí"
NEXT_PUBLIC_TIMEZONE="America/Puerto_Rico"

# Cron secret (for /api/cron/accrue-pto)
CRON_SECRET="replace-with-a-random-string"

# Initial admin (used only by seed script)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Administrador"
